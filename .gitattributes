# Keep the release source tarball (git archive, used by the Homebrew formula)
# lean: exclude everything the build doesn't need — docs site, demo media, the
# Remotion promo project. These stay in the repo (GitHub Pages serves /docs);
# they're only omitted from `git archive` / the release download.
/docs export-ignore
/assets export-ignore
/promo export-ignore
/.github export-ignore
.gitattributes export-ignore
.gitignore export-ignore
CLAUDE.md export-ignore
